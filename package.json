{
  "name": "converter",
  "version": "1.0.0",
  "description": "Odds Converter",
  "main": "app.js",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "start": "esbuild src/js/app.ts src/js/popup.js --bundle --platform=browser --format=iife --outdir=assets --servedir=.",
    "build": "esbuild src/js/app.ts src/js/popup.js --bundle --platform=browser --format=iife --outdir=assets --minify",
    "test": "node --import tsx --test tests/*.ts",
    "embed": "cp assets/app.js embed/ && cp assets/app.css embed/",
    "make": "rm -rf .build/ && mkdir .build && cp index.html ./.build/ && cp service-worker.js ./.build/ && cp manifest.json ./.build/ && cp robots.txt ./.build/ && cp -R assets/ ./.build/assets/ && cp -R embed/ ./.build/embed/"
  },
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "git@github.com:levonium/odds-converter.git"
  },
  "author": "Levon Avetyan",
  "license": "ISC"
}
